PORT=8787

# LiveKit Cloud or self-hosted LiveKit.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_TRANSCRIBER_AGENT_NAME=transcriber
LIVEKIT_STT_MODEL=deepgram/nova-3
LIVEKIT_STT_LANGUAGE=en

# Optional. Without this, the server uses a deterministic local suggestion engine.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
COPILOT_ANALYSIS_INTERVAL_MS=10000
