{
  "name": "discovery-copilot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "concurrently \"npm:dev:api\" \"npm:dev:web\" \"npm:dev:stt\"",
    "dev:all": "pnpm dev",
    "dev:api": "tsx server/index.ts",
    "dev:stt": "tsx agents/transcriber.ts dev",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc && tsc -p tsconfig.server.json && vite build",
    "start": "node build/server/index.js",
    "start:stt": "node build/agents/transcriber.js start",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@livekit/agents": "^1.4.5",
    "@livekit/agents-plugin-silero": "^1.4.5",
    "@livekit/components-react": "^2.9.14",
    "@livekit/components-styles": "^1.1.6",
    "@livekit/rtc-node": "^0.13.29",
    "@moss-dev/moss": "^1.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "livekit-client": "^2.9.9",
    "livekit-server-sdk": "^2.10.2",
    "lucide-react": "^0.468.0",
    "openai": "^4.77.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^25.9.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
